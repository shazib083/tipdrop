# ============================================================
# TipDrop — Environment Variables
# Copy this file to .env.local and fill in all values
# ============================================================

# ----- App -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-change-this

# ----- Database (Supabase / PostgreSQL) -----
DATABASE_URL=postgresql://postgres:password@localhost:5432/tipdrop
DIRECT_URL=postgresql://postgres:password@localhost:5432/tipdrop

# ----- Circle SDK (USDC Payments) -----
CIRCLE_API_KEY=your-circle-api-key
CIRCLE_WALLET_SET_ID=your-circle-wallet-set-id
CIRCLE_ENTITY_SECRET=your-circle-entity-secret
NEXT_PUBLIC_CIRCLE_APP_ID=your-circle-app-id

# ----- Arc Testnet (Blockchain) -----
NEXT_PUBLIC_ARC_TESTNET_RPC=https://rpc.testnet.arc.fun
NEXT_PUBLIC_ARC_CHAIN_ID=1116
NEXT_PUBLIC_USDC_CONTRACT=0x0000000000000000000000000000000000000000
ARC_PRIVATE_KEY=your-arc-relayer-private-key

# ----- WalletConnect -----
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ----- Email (via Resend) -----
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=noreply@tipdrop.app

# ----- Optional: Redis (rate limiting) -----
# REDIS_URL=redis://localhost:6379
